---
---
<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AGYL · The operating layer for AI-ready data</title>
<meta name="description" content="AGYL is the operating layer for AI-ready data. The layer above the foundation model where your records, standards, and judgments compound into an asset you own. Built for the AI bottleneck every serious business is now facing.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0A0A0A;
    --bg-2:#0F0F0F;
    --bg-3:#141414;
    --ink:#F5F4F1;
    --ink-2:rgba(245,244,241,.92);
    --mute:rgba(245,244,241,.62);
    --faint:rgba(245,244,241,.42);
    --dim:rgba(245,244,241,.24);
    --hair:rgba(245,244,241,.10);
    --hair-2:rgba(245,244,241,.05);
    --live:#D4D2C5;
    --warn:#C9A875;
    --green:#7A9A7F;
    --red:#B87878;
    --font:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
    --mono:'JetBrains Mono',ui-monospace,monospace;
  }
  *{box-sizing:border-box}
  html,body{margin:0;padding:0}
  html{scroll-behavior:smooth;background:var(--bg)}
  body{
    background:var(--bg);color:var(--ink);font-family:var(--font);
    font-size:16px;line-height:1.55;-webkit-font-smoothing:antialiased;
    text-rendering:optimizeLegibility;font-feature-settings:"ss01","cv11";overflow-x:hidden;
    position:relative;
  }
  /* atmospheric depth — radial warm under hero, very subtle */
  body::before{
    content:""; position:fixed; inset:0; pointer-events:none; z-index:-1;
    background:
      radial-gradient(80% 60% at 50% 0%, rgba(212,210,197,.045) 0%, transparent 60%),
      radial-gradient(120% 80% at 100% 100%, rgba(122,154,127,.025) 0%, transparent 55%),
      radial-gradient(100% 80% at 0% 100%, rgba(201,168,117,.025) 0%, transparent 55%);
  }
  /* fine grain noise via repeating pattern */
  body::after{
    content:""; position:fixed; inset:0; pointer-events:none; z-index:-1;
    opacity:.4;
    background-image:
      radial-gradient(rgba(255,255,255,.012) 1px, transparent 1px);
    background-size:3px 3px;
    mix-blend-mode:overlay;
  }
  ::selection{ background:var(--ink); color:var(--bg); }
  a{color:inherit}
  .wrap{ max-width:1380px; margin:0 auto; padding:0 64px; }

  nav.top{
    position:fixed; top:0; left:0; right:0; z-index:50;
    background:rgba(10,10,10,.72);
    backdrop-filter:blur(18px) saturate(120%);
    -webkit-backdrop-filter:blur(18px) saturate(120%);
    border-bottom:1px solid var(--hair-2);
  }
  .navrow{
    display:flex; align-items:center; justify-content:space-between;
    padding:18px 64px; max-width:1380px; margin:0 auto;
  }
  .brand{
    font-weight:600; font-size:18px; letter-spacing:-.01em;
    text-decoration:none; display:flex; align-items:center; gap:14px;
  }
  .brand .live-dot{
    width:7px; height:7px; border-radius:50%; background:var(--live);
    box-shadow:0 0 0 0 rgba(212,210,197,.6);
    animation:pulse 2.6s ease-out infinite;
  }
  @keyframes pulse{
    0%{box-shadow:0 0 0 0 rgba(212,210,197,.5);}
    70%{box-shadow:0 0 0 10px rgba(212,210,197,0);}
    100%{box-shadow:0 0 0 0 rgba(212,210,197,0);}
  }
  .navlinks{ display:flex; gap:34px; }
  .navlinks a{ color:var(--mute); text-decoration:none; font-size:13.5px; font-weight:400; transition:color .15s; }
  .navlinks a:hover{ color:var(--ink); }
  .navcta{
    color:var(--ink); text-decoration:none; border:1px solid var(--hair);
    padding:9px 16px; font-size:13.5px; font-weight:500; transition:all .15s;
  }
  .navcta:hover{ background:var(--ink); color:var(--bg); border-color:var(--ink); }

  header.hero{
    min-height:100vh; display:flex; flex-direction:column; justify-content:space-between;
    padding:160px 0 56px; position:relative;
  }
  .hero-meta{
    display:flex; gap:18px; align-items:center;
    font-family:var(--mono); font-size:11px; letter-spacing:.16em;
    color:var(--faint); text-transform:uppercase; margin-bottom:56px;
  }
  .hero-meta .mark{
    display:flex; align-items:center; gap:8px; color:var(--ink);
  }
  .hero-meta .mark::before{
    content:""; width:5px; height:5px; border-radius:50%; background:var(--live);
    box-shadow:0 0 6px var(--live);
  }
  .hero-meta .div{ color:var(--dim); }

  h1.hero-title{
    font-weight:400; font-size:clamp(48px, 6.6vw, 100px);
    line-height:1.0; letter-spacing:-.035em; margin:0; max-width:22ch;
  }
  h1.hero-title em{ font-style:normal; color:var(--mute); }

  .hero-grid{
    margin-top:56px;
    display:grid; grid-template-columns:1fr 1.05fr; gap:64px; align-items:end;
  }
  .hero-copy p{ font-size:18.5px; line-height:1.55; color:var(--ink-2); max-width:46ch; margin:0 0 18px; }
  .hero-copy p:last-of-type{ margin-bottom:0; color:var(--mute); }
  .hero-copy p b{ color:var(--ink); font-weight:500; }
  .hero-cta-row{ display:flex; gap:14px; margin-top:36px; }

  /* hero live visual */
  .hero-vis{
    background:var(--bg-2);
    border:1px solid var(--hair);
    padding:20px 20px 18px;
    aspect-ratio: 5/3.6;
  }
  .hero-vis .vh{
    display:flex; justify-content:space-between; align-items:center;
    padding-bottom:14px; margin-bottom:14px;
    border-bottom:1px solid var(--hair);
    font-family:var(--mono); font-size:10px; letter-spacing:.18em;
    color:var(--faint); text-transform:uppercase;
  }
  .hero-vis .vh .live{
    color:var(--ink); display:flex; align-items:center; gap:7px;
  }
  .hero-vis .vh .live::before{
    content:""; width:5px; height:5px; border-radius:50%; background:var(--live);
    box-shadow:0 0 6px var(--live);
  }
  .hero-vis svg{ width:100%; height:auto; display:block; }

  .btn{
    display:inline-flex; align-items:center; gap:10px;
    padding:13px 22px; font-family:var(--font); font-size:14px; font-weight:500;
    text-decoration:none; transition:all .15s; border:1px solid;
  }
  .btn-primary{ background:var(--ink); color:var(--bg); border-color:var(--ink); }
  .btn-primary:hover{ background:transparent; color:var(--ink); }
  .btn-ghost{ background:transparent; color:var(--ink); border-color:var(--hair); }
  .btn-ghost:hover{ border-color:var(--ink); }
  .btn .arr{ transition:transform .15s; }
  .btn:hover .arr{ transform:translateX(3px); }

  .hero-foot{
    display:grid; grid-template-columns:1fr 1fr; gap:1px;
    margin-top:64px;
    background:var(--hair);
    border-top:1px solid var(--hair); border-bottom:1px solid var(--hair);
  }
  .hero-foot div{
    background:var(--bg); padding:24px 28px;
    font-family:var(--mono); font-size:10.5px; letter-spacing:.16em;
    color:var(--faint); text-transform:uppercase;
    display:flex; flex-direction:column; gap:10px;
  }
  .hero-foot div b{
    color:var(--ink); font-family:var(--font);
    font-weight:500; font-size:18px; letter-spacing:-.01em;
    text-transform:none; line-height:1.25;
  }

  section{ padding:140px 0; position:relative; border-top:1px solid var(--hair); }
  .section-mark{
    display:grid; grid-template-columns:auto 1fr; gap:28px;
    font-family:var(--mono); font-size:11px; letter-spacing:.16em;
    color:var(--faint); text-transform:uppercase; margin-bottom:56px;
  }
  .section-mark.single{
    grid-template-columns:1fr;
    display:flex; align-items:center; gap:16px;
  }
  .section-mark.single::after{
    content:""; flex:1; height:1px; background:var(--hair);
  }
  .section-mark.single div{ color:var(--ink); font-weight:500; }
  .section-mark b{ color:var(--ink); font-weight:500; }
  h2{
    font-weight:400; font-size:clamp(38px, 4.6vw, 64px);
    line-height:1.04; letter-spacing:-.025em; margin:0; max-width:18ch;
  }
  h2 em{ font-style:normal; color:var(--mute); }
  .lede{
    font-size:clamp(20px,1.7vw,24px); line-height:1.5; color:var(--ink-2);
    max-width:54ch; margin:40px 0 0; font-weight:400;
  }
  p.body{ font-size:17px; line-height:1.7; color:var(--mute); max-width:62ch; margin:0 0 20px; }
  p.body b{ color:var(--ink); font-weight:500; }

  /* WHAT AGYL IS — three plain answers */
  .three-q{
    display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    background:var(--hair); margin-top:64px;
    border-top:1px solid var(--hair); border-bottom:1px solid var(--hair);
  }
  .q{ background:var(--bg); padding:48px 40px; }
  .q .q-num{ font-family:var(--mono); font-size:11px; letter-spacing:.16em; color:var(--faint); margin-bottom:22px; }
  .q .q-ask{ font-family:var(--mono); font-size:13px; letter-spacing:.04em; color:var(--ink); margin-bottom:24px; padding-bottom:18px; border-bottom:1px solid var(--hair); }
  .q .q-ans{ font-size:16.5px; line-height:1.6; color:var(--mute); margin:0; }
  .q .q-ans b{ color:var(--ink); font-weight:500; }

  /* premise */
  .premise{ padding:200px 0; }
  .premise h2{ font-size:clamp(48px,6vw,88px); max-width:20ch; }

  /* WHY NOW STATS */
  .why-stats{
    display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    background:var(--hair); margin-top:48px;
    border-top:1px solid var(--hair); border-bottom:1px solid var(--hair);
  }
  .stat{ background:var(--bg); padding:40px 32px; }
  .stat .stat-n{
    font-size:clamp(44px,4.4vw,64px); font-weight:300; letter-spacing:-.035em;
    line-height:.95; margin-bottom:24px;
  }
  .stat .stat-c{
    font-size:14px; line-height:1.55; color:var(--mute);
    border-top:1px solid var(--hair-2); padding-top:16px;
  }
  .stat .stat-src{
    display:block; margin-top:12px;
    font-family:var(--mono); font-size:10px; letter-spacing:.16em;
    color:var(--faint); text-transform:uppercase;
  }
  @media (max-width:1000px){
    .why-stats{ grid-template-columns:1fr; }
  }

  /* outcomes */
  .outcomes{
    display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    background:var(--hair); margin-top:80px;
    border-top:1px solid var(--hair); border-bottom:1px solid var(--hair);
  }
  .outcome{ background:var(--bg); padding:48px 40px; }
  .outcome .ico{ font-family:var(--mono); font-size:11px; letter-spacing:.16em; color:var(--faint); margin-bottom:36px; }
  .outcome h4{ font-weight:400; font-size:30px; letter-spacing:-.02em; line-height:1.1; margin:0 0 18px; max-width:14ch; }
  .outcome p{ font-size:15px; line-height:1.6; color:var(--mute); margin:0; }

  .op-loop{
    display:grid; grid-template-columns:repeat(3, 1fr); gap:1px;
    background:var(--hair); margin-top:64px;
    border-top:1px solid var(--hair); border-bottom:1px solid var(--hair);
  }
  .op-card{ background:var(--bg); padding:48px 40px 52px; transition:background .3s; }
  .op-card:hover{ background:var(--bg-2); }
  .op-card .step{ font-family:var(--mono); font-size:11px; letter-spacing:.18em; color:var(--faint); margin-bottom:22px; }
  .op-card h4{ font-weight:500; font-size:26px; letter-spacing:-.02em; margin:0 0 18px; line-height:1.1; }
  .op-card p{ font-size:15px; line-height:1.6; color:var(--mute); margin:0; }
  .loop-note{
    display:flex; justify-content:space-between; align-items:center;
    padding:24px 0 0; font-family:var(--mono); font-size:11px;
    letter-spacing:.16em; color:var(--faint); text-transform:uppercase;
  }
  .loop-note span:first-child{ display:flex; align-items:center; gap:12px; }
  .loop-note span:first-child::before{
    content:""; width:6px; height:6px; border-radius:50%;
    background:var(--live); box-shadow:0 0 8px var(--live);
  }

  .context-graph{ margin-top:72px; padding:0; border:1px solid var(--hair); background:var(--bg-2); position:relative; }
  .context-head{
    padding:28px 48px; border-bottom:1px solid var(--hair);
    display:flex; justify-content:space-between; align-items:center;
    font-family:var(--mono); font-size:11px; letter-spacing:.14em;
    color:var(--faint); text-transform:uppercase;
  }
  .context-head .live-pill{ display:flex; align-items:center; gap:8px; color:var(--ink); }
  .context-head .live-pill::before{
    content:""; width:6px; height:6px; border-radius:50%;
    background:var(--live); box-shadow:0 0 6px var(--live);
  }
  .context-graph svg{ width:100%; height:auto; display:block; }
  .context-foot{
    padding:24px 48px; border-top:1px solid var(--hair);
    display:grid; grid-template-columns:repeat(3,1fr); gap:32px;
    font-family:var(--mono); font-size:11px; letter-spacing:.04em; color:var(--mute);
  }
  .context-foot b{
    display:block; color:var(--ink); font-weight:500; font-family:var(--font);
    font-size:14px; letter-spacing:0; text-transform:none; margin-bottom:6px;
  }

  /* use case tabs */
  .uc-intro{
    display:grid; grid-template-columns:1.2fr 1fr; gap:64px;
    margin-top:48px; align-items:start;
  }
  .uc-intro p.body{ font-size:18.5px; }
  .uc-connector{
    border-left:1px solid var(--hair); padding-left:40px;
    font-size:14px; line-height:1.6; color:var(--mute);
  }
  .uc-connector b{ display:block; font-family:var(--mono); font-size:11px;
    letter-spacing:.18em; color:var(--ink); text-transform:uppercase; margin-bottom:14px; }

  .uc-nav{
    display:flex; gap:0; border-bottom:1px solid var(--hair); margin-top:64px;
    overflow-x:auto; scrollbar-width:none;
  }
  .uc-nav::-webkit-scrollbar{ display:none; }
  .uc-nav button{
    background:none; border:none; color:var(--mute);
    font-family:var(--font); font-size:14px; font-weight:500;
    padding:18px 24px; cursor:pointer;
    border-bottom:2px solid transparent; margin-bottom:-1px;
    transition:all .2s; white-space:nowrap; letter-spacing:-.005em;
    display:flex; align-items:center; gap:10px;
  }
  .uc-nav button .uc-num{ font-family:var(--mono); font-size:11px; color:var(--faint); letter-spacing:.08em; }
  .uc-nav button:hover{ color:var(--ink); }
  .uc-nav button.active{ color:var(--ink); border-bottom-color:var(--ink); }
  .uc-nav button.active .uc-num{ color:var(--ink); }

  .uc-panel{ display:none; padding-top:64px; }
  .uc-panel.active{ display:block; animation:fadein .5s ease; }
  @keyframes fadein{ from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;} }
  .uc-grid{ display:grid; grid-template-columns:1fr 1.2fr; gap:80px; align-items:start; }
  .uc-content .uc-label{ font-family:var(--mono); font-size:11px; letter-spacing:.18em; color:var(--faint); text-transform:uppercase; margin-bottom:24px; }
  .uc-content h3{ font-weight:400; font-size:clamp(32px,3.4vw,44px); line-height:1.08; letter-spacing:-.025em; margin:0 0 28px; max-width:18ch; }
  .uc-content h3 em{ font-style:normal; color:var(--mute); }
  .uc-content p.body{ font-size:16.5px; line-height:1.65; }
  .uc-content .uc-impact{
    margin-top:36px; padding:28px 0 0; border-top:1px solid var(--hair);
    display:grid; grid-template-columns:1fr 1fr; gap:32px;
  }
  .uc-content .uc-impact div{ font-family:var(--mono); font-size:11px; letter-spacing:.12em; color:var(--faint); text-transform:uppercase; }
  .uc-content .uc-impact b{
    display:block; font-family:var(--font); color:var(--ink); font-weight:500;
    font-size:17px; letter-spacing:-.01em; text-transform:none; margin-top:8px; line-height:1.35;
  }
  .uc-content .uc-cross{
    margin-top:28px; padding:18px 22px;
    background:var(--bg-2); border:1px solid var(--hair-2);
    font-family:var(--mono); font-size:11px; line-height:1.55;
    color:var(--mute); letter-spacing:.02em;
  }
  .uc-content .uc-cross b{ color:var(--ink); font-weight:500; }

  .uc-visual{
    background:var(--bg-2); border:1px solid var(--hair);
    padding:40px 36px; min-height:520px;
    display:flex; flex-direction:column;
  }
  .uc-visual .uc-vh{
    font-family:var(--mono); font-size:10.5px; letter-spacing:.18em;
    color:var(--faint); text-transform:uppercase;
    padding-bottom:20px; border-bottom:1px solid var(--hair); margin-bottom:24px;
    display:flex; justify-content:space-between; align-items:center;
  }
  .uc-visual .uc-vh .live{ color:var(--ink); display:flex; align-items:center; gap:8px; }
  .uc-visual .uc-vh .live::before{
    content:""; width:5px; height:5px; border-radius:50%;
    background:var(--live); box-shadow:0 0 6px var(--live);
  }
  .uc-visual svg{ width:100%; height:auto; display:block; flex:1; }

  /* records-talk diagram */
  .records-talk{
    margin-top:96px; padding:48px 56px;
    background:var(--bg-2); border:1px solid var(--hair);
  }
  .records-talk h4{ font-weight:500; font-size:20px; letter-spacing:-.01em; margin:0 0 8px; }
  .records-talk .sub{ font-family:var(--mono); font-size:11px; letter-spacing:.18em; color:var(--faint); text-transform:uppercase; margin-bottom:32px; }
  .records-talk svg{ width:100%; height:auto; display:block; }

  /* EKOM */
  .ekom-block{
    display:grid; grid-template-columns:1fr 1fr; gap:80px;
    margin-top:56px; align-items:start;
  }
  .ekom-mark{
    font-family:var(--mono); font-size:11px; letter-spacing:.18em;
    color:var(--faint); text-transform:uppercase; margin-bottom:18px;
  }
  .ekom-tagline{ font-size:18px; line-height:1.5; color:var(--mute); }
  .ekom-tagline b{ color:var(--ink); font-weight:500; }
  .ekom-stats{
    display:grid; grid-template-columns:1fr 1fr; gap:1px; background:var(--hair);
    border:1px solid var(--hair); margin-top:32px;
  }
  .ekom-stat{ background:var(--bg); padding:32px 28px; }
  .ekom-stat .n{ font-size:clamp(32px,3.2vw,42px); font-weight:300; letter-spacing:-.025em; line-height:1; }
  .ekom-stat .c{ font-size:12.5px; line-height:1.5; color:var(--mute); margin-top:14px; font-family:var(--mono); letter-spacing:.02em; }
  .ekom-quote{ font-size:20px; line-height:1.5; letter-spacing:-.01em; color:var(--ink-2); font-weight:300; }
  .ekom-quote-attr{
    margin-top:20px; padding-top:18px; border-top:1px solid var(--hair);
    font-family:var(--mono); font-size:11px; letter-spacing:.12em;
    color:var(--faint); text-transform:uppercase;
  }

  /* principles */
  .principles{ margin-top:48px; display:grid; grid-template-columns:1fr 1fr; }
  .principle{ padding:40px 48px 40px 0; border-top:1px solid var(--hair); min-height:160px; display:flex; flex-direction:column; }
  .principle:nth-child(even){ padding-left:48px; padding-right:0; border-left:1px solid var(--hair); }
  .principle:nth-last-child(-n+2){ border-bottom:1px solid var(--hair); }
  .principle .n{ font-family:var(--mono); font-size:11px; letter-spacing:.18em; color:var(--faint); margin-bottom:14px; }
  .principle h5{ font-weight:500; font-size:22px; letter-spacing:-.015em; line-height:1.2; margin:0 0 12px; }
  .principle p{ font-size:15px; line-height:1.6; color:var(--mute); margin:0; max-width:48ch; }

  .close{ padding:200px 0 220px; }
  .close h2{ font-size:clamp(48px,6vw,96px); max-width:18ch; line-height:1.0; }
  .close .cta-row{ margin-top:64px; display:flex; gap:18px; align-items:center; }

  footer.foot{
    padding:48px 0; border-top:1px solid var(--hair);
    display:grid; grid-template-columns:1fr auto; gap:48px; align-items:end;
  }
  .foot-brand{ font-size:14px; color:var(--mute); line-height:1.6; }
  .foot-brand b{ display:block; color:var(--ink); font-weight:500; font-size:20px; letter-spacing:-.015em; margin-bottom:14px; }
  .foot-links{ display:flex; gap:36px; font-family:var(--mono); font-size:11px; letter-spacing:.14em; text-transform:uppercase; }
  .foot-links a{ color:var(--faint); text-decoration:none; transition:color .15s; }
  .foot-links a:hover{ color:var(--ink); }
  .foot-final{
    grid-column:1 / -1; padding-top:32px; margin-top:48px;
    border-top:1px solid var(--hair-2);
    display:flex; justify-content:space-between;
    font-family:var(--mono); font-size:11px; letter-spacing:.1em; color:var(--faint);
  }

  .reveal{ opacity:0; transform:translateY(20px); transition:opacity .9s ease, transform .9s ease; }
  .reveal.in{ opacity:1; transform:none; }

  /* WHAT YOU GET — three pillars */
  .pillars{
    display:grid; grid-template-columns:repeat(3,1fr); gap:1px;
    background:var(--hair); margin-top:64px;
