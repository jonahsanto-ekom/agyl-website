  }
  .ekom-flagship .wrap{ padding-top:120px; padding-bottom:120px; }
  .ekom-flagship .ekom-mark-top{
    display:flex; align-items:center; gap:14px;
    font-family:var(--mono); font-size:11px; letter-spacing:.18em;
    color:var(--ink); text-transform:uppercase; margin-bottom:48px;
  }
  .ekom-flagship .ekom-mark-top::before{
    content:""; width:24px; height:1px; background:var(--ink);
  }
  .ekom-flagship .ekom-mark-top::after{
    content:""; flex:1; height:1px; background:var(--hair);
  }
  .ekom-flagship .flagship-grid{
    display:grid; grid-template-columns:1.1fr 1fr; gap:80px;
    align-items:start;
  }
  .ekom-flagship .flagship-left .ekom-wordmark{
    font-size:clamp(72px,9vw,128px); font-weight:300;
    letter-spacing:-.045em; line-height:.9;
    margin:0 0 28px;
    display:flex; align-items:baseline; gap:18px;
  }
  .ekom-flagship .flagship-left .ekom-wordmark span{
    font-family:var(--mono); font-size:13px; font-weight:500;
    letter-spacing:.18em; color:var(--faint); text-transform:uppercase;
  }
  .ekom-flagship .flagship-left .ekom-h{
    font-weight:400; font-size:clamp(28px,3vw,38px);
    line-height:1.1; letter-spacing:-.02em; margin:0 0 24px;
    max-width:22ch;
  }
  .ekom-flagship .flagship-left .ekom-h em{ font-style:normal; color:var(--mute); }
  .ekom-flagship .flagship-left .ekom-desc{
    font-size:17px; line-height:1.65; color:var(--mute); max-width:50ch; margin:0 0 18px;
  }
  .ekom-flagship .flagship-left .ekom-desc b{ color:var(--ink); font-weight:500; }
  .ekom-flagship .flagship-left .ekom-cta{ margin-top:32px; display:flex; gap:14px; align-items:center; }
  .ekom-flagship .flagship-left .ekom-cta .live-tag{
    font-family:var(--mono); font-size:11px; letter-spacing:.18em;
    color:var(--ink); text-transform:uppercase;
    display:flex; align-items:center; gap:8px;
  }
  .ekom-flagship .flagship-left .ekom-cta .live-tag::before{
    content:""; width:6px; height:6px; border-radius:50%;
    background:var(--live); box-shadow:0 0 6px var(--live);
  }
  .ekom-flagship .flagship-stats{
    display:grid; grid-template-columns:1fr 1fr; gap:1px;
    background:var(--hair); border:1px solid var(--hair);
  }
  .ekom-flagship .fs-stat{ background:var(--bg-2); padding:32px 28px; }
  .ekom-flagship .fs-stat .n{ font-size:clamp(32px,3.2vw,42px); font-weight:300; letter-spacing:-.025em; line-height:1; }
  .ekom-flagship .fs-stat .c{ font-size:13.5px; line-height:1.5; color:var(--mute); margin-top:14px; font-family:var(--mono); letter-spacing:.02em; }
  .ekom-flagship .flagship-quote{
    margin-top:32px; padding:32px 36px;
    background:var(--bg); border:1px solid var(--hair);
  }
  .ekom-flagship .flagship-quote .q{
    font-size:18px; line-height:1.5; color:var(--ink-2); font-weight:300;
    margin:0 0 18px; letter-spacing:-.01em;
  }
  .ekom-flagship .flagship-quote .attr{
    padding-top:14px; border-top:1px solid var(--hair);
    font-family:var(--mono); font-size:11px; letter-spacing:.12em;
    color:var(--faint); text-transform:uppercase;
  }
  .ekom-flagship .verticals{
    margin-top:48px;
    padding-top:28px; border-top:1px solid var(--hair);
    display:grid; grid-template-columns:auto 1fr; gap:32px; align-items:start;
  }
  .ekom-flagship .verticals .vt{
    font-family:var(--mono); font-size:11px; letter-spacing:.18em;
    color:var(--faint); text-transform:uppercase;
  }
  .ekom-flagship .verticals .vl{
    display:flex; gap:24px; flex-wrap:wrap;
    font-size:14px; color:var(--ink);
  }
  .ekom-flagship .verticals .vl span{
    padding:6px 14px; border:1px solid var(--hair);
    font-family:var(--mono); font-size:11.5px; letter-spacing:.04em;
  }
  .ekom-flagship .verticals-note{
    margin-top:18px; padding-top:18px; border-top:1px solid var(--hair-2);
    font-size:14.5px; color:var(--mute); max-width:64ch;
    font-style:italic;
  }
  @media (max-width:1000px){
    .ekom-flagship .flagship-grid{ grid-template-columns:1fr; gap:48px; }
    .ekom-flagship .flagship-stats{ grid-template-columns:1fr; }
    .ekom-flagship .verticals{ grid-template-columns:1fr; gap:14px; }
  }

  .svg-lbl{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;fill:#F5F4F1;letter-spacing:.02em}
  .svg-lbl-mute{font-family:'JetBrains Mono',monospace;font-size:11.5px;font-weight:400;fill:rgba(245,244,241,.55);letter-spacing:.02em}
  .svg-cap{font-family:'JetBrains Mono',monospace;font-size:11px;font-weight:500;letter-spacing:.18em;fill:rgba(245,244,241,.42);text-transform:uppercase}
  .svg-h{font-family:'Inter',sans-serif;font-size:14px;font-weight:500;fill:#F5F4F1;letter-spacing:-.005em}
  .svg-num{font-family:'Inter',sans-serif;font-size:22px;font-weight:400;fill:#F5F4F1;letter-spacing:-.02em}

  /* hero ambient streaming */
  .stream{ stroke-dasharray:5 7; animation:streamflow 3.4s linear infinite; }
  @keyframes streamflow{ to{ stroke-dashoffset:-72; } }

  @media (max-width:1100px){
    .hero-grid{ grid-template-columns:1fr; gap:40px; }
    .hero-vis{ aspect-ratio:auto; }
    .uc-intro{ grid-template-columns:1fr; gap:32px; }
    .uc-connector{ border-left:none; padding-left:0; border-top:1px solid var(--hair); padding-top:24px; }
  }
  @media (max-width:1000px){
    .wrap, .navrow{ padding-left:32px; padding-right:32px; }
    .navlinks{ display:none; }
    .hero-foot{ grid-template-columns:1fr 1fr; gap:1px; }
    .ekom-block{ grid-template-columns:1fr; gap:48px; }
    .op-loop, .outcomes, .three-q{ grid-template-columns:1fr; }
    .principles{ grid-template-columns:1fr; }
    .principle{ padding:32px 0 !important; border-left:none !important; }
    .uc-grid{ grid-template-columns:1fr; gap:48px; }
    .uc-content .uc-impact{ grid-template-columns:1fr; }
    section{ padding:90px 0; }
    .context-head, .context-foot{ padding:24px 24px; }
    .context-foot{ grid-template-columns:1fr; gap:18px; }
    .records-talk{ padding:32px 24px; }
  }
  @media (max-width:600px){
    .wrap, .navrow{ padding-left:22px; padding-right:22px; }
    h1.hero-title{ font-size:clamp(36px,10vw,52px); }
    h2{ font-size:clamp(28px,8vw,40px); }
    .hero-foot{ grid-template-columns:1fr; gap:1px; }
    .uc-visual{ padding:24px 20px; min-height:auto; }
  }
  /* MOTION: card hover lift on pillars/principles/use cases/outcomes */
  .pillar, .principle, .outcome, .uc-nav button{
    transition: border-color .35s ease, transform .35s ease, background-color .35s ease;
  }
  .pillar:hover, .outcome:hover{
    transform: translateY(-1px);
  }
  .pillar:hover{ background:rgba(245,244,241,.018); }
  .outcome:hover{ background:rgba(245,244,241,.018); }
  .principle:hover{ background:rgba(245,244,241,.015); }
  .uc-nav button:hover{ border-color: rgba(245,244,241,.28); }

  /* MOTION: hero progress bar slow pulse loop */
  .hp-bar-loop{
    transform-origin:left center;
    animation:hpBarLoop 4.5s ease-in-out infinite;
  }
  @keyframes hpBarLoop{
    0%{ opacity:.55; transform:scaleX(.18); }
    50%{ opacity:1; transform:scaleX(1); }
    100%{ opacity:.55; transform:scaleX(.18); }
  }

  /* MOTION: activity feed row pulse-highlight */
  .ow-row{
    animation:owFade 6s ease-in-out infinite;
  }
  @keyframes owHighlight{
    0%,100%{ fill-opacity:0; }
    10%,30%{ fill-opacity:.04; }
  }

  /* MOTION: count-up stat reveal */
  .count-up{ opacity:0; transition:opacity .4s ease; }
  .count-up.in{ opacity:1; }

  @media (prefers-reduced-motion:reduce){
    .brand .live-dot, .context-head .live-pill::before, .uc-visual .uc-vh .live::before, .hero-vis .vh .live::before, .loop-note span:first-child::before, .stream, .hp-bar-loop, .ow-row{ animation:none !important; }
    .reveal{ opacity:1; transform:none; }
    .count-up{ opacity:1; }
  }
</style>
</head>
<body>
  <slot />
<script is:inline>
  const reveals = document.querySelectorAll('section, .context-graph, .records-talk');
  reveals.forEach(el => el.classList.add('reveal'));
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.06 });
  reveals.forEach(el => io.observe(el));

  const ucNav = document.getElementById('uc-nav');
  const ucButtons = ucNav ? ucNav.querySelectorAll('button') : [];
  const ucPanels = document.querySelectorAll('.uc-panel');
  ucButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.uc;
      ucButtons.forEach(b => b.classList.toggle('active', b === btn));
      ucPanels.forEach(p => p.classList.toggle('active', p.id === 'uc-' + id));
    });
  });

  // Count-up animation for statistics
  const easeOutCubic = (t) => 1 - Math.pow(1 - t, 3);
  function animateCountUp(el, target, prefix, suffix, duration) {
    const start = performance.now();
    function tick(now) {
      const t = Math.min(1, (now - start) / duration);
      const eased = easeOutCubic(t);
      const value = target * eased;
      let display;
      if (target >= 1000000) display = (value / 1000000).toFixed(1) + 'M';
      else if (target >= 1000) display = Math.round(value / 1000) + 'K';
      else if (Number.isInteger(target)) display = Math.round(value).toString();
      else display = value.toFixed(1);
      el.textContent = prefix + display + suffix;
      if (t < 1) requestAnimationFrame(tick);
      else el.textContent = prefix + (target >= 1000000 ? (target/1000000).toFixed(1)+'M' : target >= 1000 ? Math.round(target/1000)+'K' : Number.isInteger(target) ? target.toString() : target.toFixed(1)) + suffix;
    }
    requestAnimationFrame(tick);
  }

  // Find and animate the big stat (60%) and supporting stats
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!reducedMotion) {
    // The big 60% stat
    const bigStat = document.querySelector('.big-stat .bs-num');
    if (bigStat) {
      const original = bigStat.textContent.trim();
      bigStat.dataset.target = original;
      const bsObs = new IntersectionObserver((entries, obs) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            const txt = e.target.dataset.target;
            const num = parseFloat(txt);
            const suffix = txt.replace(/[\d.]/g, '');
            e.target.textContent = '0' + suffix;
            animateCountUp(e.target, num, '', suffix, 1400);
            obs.unobserve(e.target);
          }
        });
      }, { threshold: 0.4 });
      bsObs.observe(bigStat);
    }

    // The 3 supporting stats
    document.querySelectorAll('.why-stats .stat-n').forEach(el => {
      const original = el.textContent.trim();
      el.dataset.target = original;
      const num = parseFloat(original);
      if (!isNaN(num)) {
        const prefix = original.match(/^[^\d]*/)[0];
        const suffix = original.replace(/^[^\d]*[\d.]+/, '');
        const obs = new IntersectionObserver((entries, observer) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.textContent = prefix + '0' + suffix;
              animateCountUp(e.target, num, prefix, suffix, 1300);
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.4 });
        obs.observe(el);
      }
    });

    // EKOM stats (2.1M, 500K, 96%, 1 week)
    document.querySelectorAll('.ekom-stat .n, .fs-stat .n').forEach(el => {
      const original = el.textContent.trim();
      el.dataset.target = original;
      // Parse compound values like "2.1M" or "500K" or "96%" or "1 week"
      const m = original.match(/^(\d+\.?\d*)([A-Za-z%]*)\s*(.*)$/);
      if (m) {
        let num = parseFloat(m[1]);
        const unit = m[2];
        const rest = m[3];
        if (unit === 'M') num = num * 1000000;
        else if (unit === 'K') num = num * 1000;
        const obs = new IntersectionObserver((entries, observer) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              e.target.textContent = '0' + (unit || '') + (rest ? ' ' + rest : '');
              animateCountUp(e.target, num, '', (unit === 'M' || unit === 'K') ? '' : unit + (rest ? ' ' + rest : ''), 1500);
              observer.unobserve(e.target);
            }
          });
        }, { threshold: 0.4 });
        obs.observe(el);
      }
    });
  }
</script>
</body>
</html>
