<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>AGYL · The operating layer for AI-ready data</title>
<meta name="description" content="AGYL is the operating layer for AI-ready data. The layer above the foundation model where your records, standards, and judgments compound into an asset you own. Built for the AI bottleneck every serious business is now facing.">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet">
<style is:global>
  :root{
    --bg:#0A0A0A;
    --bg-2:#0F0F0F;
    --bg-3:#141414;
    --bg-lift:#161616;
    --bg-lift-2:#1A1A1A;
    --ink:#F5F4F1;
    --ink-2:rgba(245,244,241,.92);
    --mute:rgba(245,244,241,.74);
    --mute-2:rgba(245,244,241,.62);
    --faint:rgba(245,244,241,.58);
    --dim:rgba(245,244,241,.32);
    --hair:rgba(245,244,241,.10);
    --hair-2:rgba(245,244,241,.05);
    --hair-lift:rgba(245,244,241,.14);
    --live:#D4D2C5;
    --warn:#C9A875;
    --accent:#4A7C6F;
    --mono:'JetBrains Mono',monospace;
    --sans:'Inter',sans-serif;
    font-family:var(--sans);
    background:var(--bg);
    color:var(--ink);
    -webkit-font-smoothing:antialiased;
  }
  *,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{background:var(--bg);overflow-x:hidden;}
  a{color:inherit;}
  img,svg{display:block;}

  /* WRAP */
  .wrap{max-width:1080px;margin:0 auto;padding:0 40px;}
  @media(max-width:768px){.wrap{padding:0 24px;}}

  /* NAV */
  nav.top{
    position:fixed; top:0; left:0; right:0; z-index:100;
    display:flex; align-items:center; justify-content:space-between;
    padding:0 40px; height:56px;
    background:rgba(10,10,10,.92); backdrop-filter:blur(12px);
    border-bottom:1px solid var(--hair);
  }
  nav.top a{text-decoration:none;}
  .brand-lockup{display:flex;align-items:center;gap:10px;}
  .brand-mark{width:18px;height:20px;color:var(--ink);flex-shrink:0;}
  .brand-wordmark{
    font-family:'Jost','Inter',sans-serif;
    font-weight:300; font-size:18px;
    letter-spacing:.18em; text-transform:uppercase;
    color:var(--ink); line-height:1;
  }
  .navlinks{display:flex;align-items:center;gap:28px;}
  .navlinks a{
    font-size:13px; color:var(--mute);
    letter-spacing:.02em; transition:color .15s;
  }
  .navlinks a:hover{color:var(--ink);}
  .nav-cta{
    font-size:13px; font-weight:500;
    padding:7px 16px; border:1px solid var(--hair-lift);
    color:var(--ink); letter-spacing:.02em;
    transition:background .15s, border-color .15s;
  }
  .nav-cta:hover{background:var(--bg-lift);border-color:var(--hair);}
  @media(max-width:900px){.navlinks{display:none;}}

  /* HERO */
  header.hero{
    padding:140px 0 80px;
    min-height:100vh; display:flex; flex-direction:column; justify-content:center;
  }
  .hero-meta{
    display:flex; align-items:center; gap:12px;
    font-family:var(--mono); font-size:11px; letter-spacing:.18em;
    text-transform:uppercase; color:var(--faint); margin-bottom:40px;
  }
  .hero-meta .mark{color:var(--live);}
  .hero-meta .div{color:var(--hair);}
  .hero-h{
    font-size:clamp(48px,7vw,88px);
    font-weight:300; line-height:1.05; letter-spacing:-.03em;
    color:var(--ink); max-width:900px;
  }
  .hero-h em{font-style:normal;color:var(--mute);}
  .hero-sub{
    font-size:clamp(15px,2vw,18px); line-height:1.65;
    color:var(--mute); max-width:600px; margin-top:32px;
  }
  .hero-cta{margin-top:48px;}

  /* BUTTONS */
  .btn{
    display:inline-flex; align-items:center; gap:8px;
    font-size:13px; font-weight:500; letter-spacing:.03em;
    padding:10px 20px; text-decoration:none; transition:all .15s;
    font-family:var(--sans);
  }
  .btn-primary{
    background:var(--ink); color:var(--bg);
  }
  .btn-primary:hover{background:var(--ink-2);}
  .btn-secondary{
    border:1px solid var(--hair-lift); color:var(--mute);
  }
  .btn-secondary:hover{border-color:var(--hair);color:var(--ink);}
  .btn .arr{ transition:transform .15s; }
  .btn:hover .arr{ transform:translateX(3px); }

  /* SECTIONS */
  section{
    padding:96px 0;
    border-top:1px solid var(--hair);
  }
  section.lifted{
    background:var(--bg-lift);
    margin:0 -40px; padding:96px 40px;
  }
  @media(max-width:768px){section.lifted{margin:0 -24px;padding:72px 24px;}}

  /* SECTION MARK */
  .section-mark{
    display:flex; align-items:center; gap:16px;
    font-family:var(--mono); font-size:11px; letter-spacing:.18em;
    text-transform:uppercase; color:var(--faint); margin-bottom:40px;
  }
  .section-mark::before{
    content:''; display:block; height:1px;
    background:var(--hair); flex:1;
  }
  .section-mark.single::before{display:none;}
  .section-mark div{white-space:nowrap;}

  /* TYPOGRAPHY */
  h2{
    font-size:clamp(28px,4vw,48px);
    font-weight:300; line-height:1.1; letter-spacing:-.02em; color:var(--ink);
    margin-bottom:24px;
  }
  h2 em{font-style:normal;color:var(--mute);}
  h3{font-size:clamp(20px,2.5vw,28px);font-weight:400;line-height:1.2;letter-spacing:-.01em;color:var(--ink);}
  h3 em{font-style:normal;color:var(--mute);}
  h5{font-size:15px;font-weight:500;line-height:1.3;letter-spacing:-.01em;color:var(--ink);margin-bottom:10px;}
  p.lede{
    font-size:clamp(15px,1.8vw,18px); line-height:1.65;
    color:var(--mute); max-width:720px; margin-bottom:48px;
  }
  p.smaller{font-size:14px;line-height:1.65;color:var(--mute);margin-top:16px;}

  /* DICTIONARY */
  section.dictionary{
    padding:80px 0; border-top:1px solid var(--hair-2);
  }
  .dict-word{
    font-size:clamp(32px,5vw,56px);
    font-weight:300; letter-spacing:-.02em; color:var(--ink);
    margin-bottom:4px;
  }
  .dict-word em{font-style:italic;color:var(--mute);}
  .dict-pron{
    font-family:var(--mono); font-size:13px;
    color:var(--faint); margin-bottom:20px;
    letter-spacing:.06em;
  }
  .dict-pos{
    font-family:var(--mono); font-size:11px;
    letter-spacing:.18em; text-transform:uppercase;
    color:var(--faint); margin-bottom:16px;
  }
  .dict-defs{}
  .dict-def{
    display:flex; gap:20px;
    font-size:16px; line-height:1.65; color:var(--mute);
    margin-bottom:12px;
  }
  .dict-def .n{
    font-family:var(--mono); font-size:11px;
    letter-spacing:.12em; color:var(--dim); padding-top:4px;
    flex-shrink:0;
  }
  .dict-also{
    margin-top:24px; padding-top:20px;
    border-top:1px solid var(--hair-2);
    font-family:var(--mono); font-size:11px;
    letter-spacing:.12em; color:var(--faint);
  }

  /* WHAT IT IS */
  .what-grid{
    display:grid; grid-template-columns:1fr 1fr 1fr 1fr;
    gap:1px; background:var(--hair);
    border:1px solid var(--hair); margin-top:48px;
  }
  .what-cell{
    background:var(--bg); padding:24px 20px;
  }
  .what-cell .label{
    font-family:var(--mono); font-size:10px;
    letter-spacing:.18em; text-transform:uppercase;
    color:var(--faint); margin-bottom:10px;
  }
  .what-cell .value{
    font-size:15px; line-height:1.4; color:var(--ink);
  }
  @media(max-width:768px){.what-grid{grid-template-columns:1fr 1fr;}}

  /* WHAT YOU GET */
  .wyg-grid{
    display:grid; grid-template-columns:1fr 1fr 1fr;
    gap:32px; margin-top:48px;
  }
  .wyg-item h3{font-size:16px;font-weight:500;margin-bottom:10px;}
  .wyg-item p{font-size:14px;line-height:1.65;color:var(--mute);}
  .wyg-item .tag{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--faint);text-transform:uppercase;margin-bottom:16px;}
  .wyg-item .sub-items{margin-top:16px;}
  .wyg-item .sub-item{font-size:13px;line-height:1.5;color:var(--mute);padding:8px 0;border-top:1px solid var(--hair-2);}
  @media(max-width:768px){.wyg-grid{grid-template-columns:1fr;}}

  /* PREMISE */
  .premise{}
  .stat-big{
    font-size:clamp(80px,14vw,160px); font-weight:300;
    letter-spacing:-.04em; color:var(--ink); line-height:.9;
    margin:48px 0 24px;
  }
  .stat-source{
    font-family:var(--mono); font-size:11px;
    letter-spacing:.12em; color:var(--faint);
    text-transform:uppercase; margin-top:8px;
  }
  .stat-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px;margin-top:48px;}
  .stat-card{padding:24px;background:var(--bg-lift);}
  .stat-card .num{font-size:clamp(28px,4vw,48px);font-weight:300;letter-spacing:-.02em;color:var(--ink);margin-bottom:12px;}
  .stat-card p{font-size:13px;line-height:1.55;color:var(--mute);}
  .stat-card .src{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--faint);text-transform:uppercase;margin-top:12px;}
  @media(max-width:768px){.stat-grid{grid-template-columns:1fr;}}

  /* OUTCOMES */
  .outcomes-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px;margin-top:48px;}
  .outcome{padding:24px;border:1px solid var(--hair);}
  .outcome .num{font-family:var(--mono);font-size:11px;letter-spacing:.12em;color:var(--faint);text-transform:uppercase;margin-bottom:16px;}
  .outcome h3{font-size:16px;font-weight:500;margin-bottom:10px;}
  .outcome p{font-size:14px;line-height:1.65;color:var(--mute);}
  @media(max-width:768px){.outcomes-grid{grid-template-columns:1fr;}}

  /* OPERATING LAYER */
  #operating-layer h2{margin-bottom:48px;}
  .op-steps{display:flex;gap:40px;margin-bottom:64px;}
  .op-step{flex:1;}
  .op-step .num{font-family:var(--mono);font-size:11px;letter-spacing:.12em;color:var(--faint);text-transform:uppercase;margin-bottom:16px;}
  .op-step h3{font-size:18px;font-weight:400;margin-bottom:12px;}
  .op-step p{font-size:14px;line-height:1.65;color:var(--mute);}
  @media(max-width:768px){.op-steps{flex-direction:column;gap:32px;}}

  /* COMPOUNDING */
  section.compounding{padding:96px 0;border-top:1px solid var(--hair);}

  /* EKOM FLAGSHIP */
  section.ekom-flagship{
    margin:0; padding:0;
    background:linear-gradient(180deg, var(--bg-2) 0%, var(--bg-3) 100%);
    border-top:1px solid var(--hair);
    border-bottom:1px solid var(--hair);
    position:relative;
  }
  section.ekom-flagship .wrap{padding-top:80px;padding-bottom:80px;}
  .ekom-mark-top{
    font-family:var(--mono); font-size:10px;
    letter-spacing:.18em; text-transform:uppercase;
    color:var(--faint); margin-bottom:40px;
  }
  .flagship-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;}
  .ekom-wordmark{font-size:clamp(20px,3vw,32px);font-weight:400;letter-spacing:-.01em;margin-bottom:16px;}
  .ekom-wordmark span{color:var(--mute);font-size:.7em;}
  .ekom-h{font-size:15px;line-height:1.6;color:var(--mute);margin-bottom:16px;}
  .ekom-h em{font-style:normal;color:var(--ink);}
  .ekom-desc{font-size:14px;line-height:1.65;color:var(--mute);margin-bottom:12px;}
  .ekom-cta{display:flex;align-items:center;gap:20px;margin-top:24px;}
  .live-tag{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--faint);text-transform:uppercase;}
  @media(max-width:768px){.flagship-grid{grid-template-columns:1fr;}}

  /* AUDIENCE */
  .audience-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:32px;margin-top:48px;}
  .aud-card{padding:28px;background:var(--bg-lift);}
  .aud-mark{font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:var(--faint);text-transform:uppercase;margin-bottom:16px;display:flex;align-items:center;gap:8px;}
  .aud-num{color:var(--dim);}
  .aud-h{font-size:16px;font-weight:400;line-height:1.35;letter-spacing:-.01em;margin-bottom:12px;}
  .aud-h em{font-style:normal;color:var(--mute);}
  .aud-card p{font-size:14px;line-height:1.65;color:var(--mute);margin-bottom:12px;}
  .aud-card p b{color:var(--ink);font-weight:500;}
  .aud-meta{font-family:var(--mono);font-size:10px;letter-spacing:.12em;color:var(--faint);text-transform:uppercase;margin-top:20px;padding-top:16px;border-top:1px solid var(--hair-2);}
  .aud-meta b{display:block;margin-top:4px;color:var(--mute);text-transform:none;letter-spacing:0;font-size:12px;}
  @media(max-width:768px){.audience-grid{grid-template-columns:1fr;}}

  /* PRINCIPLES */
  .principles{display:grid;grid-template-columns:1fr 1fr;gap:32px;margin-top:48px;}
  .principle{padding:28px;border:1px solid var(--hair);}
  .principle .n{font-family:var(--mono);font-size:10px;letter-spacing:.18em;color:var(--faint);text-transform:uppercase;margin-bottom:16px;}
  .principle h5{font-size:15px;margin-bottom:10px;}
  .principle p{font-size:14px;line-height:1.65;color:var(--mute);}
  @media(max-width:768px){.principles{grid-template-columns:1fr;}}

  /* COMPANY */
  .company-grid{display:grid;grid-template-columns:1fr 1fr;gap:80px;margin-top:48px;}
  .col-l p{font-size:15px;line-height:1.7;color:var(--mute);margin-bottom:16px;}
  .col-l p b{color:var(--ink);font-weight:500;}
  .meta-row{display:flex;gap:24px;padding:16px 0;border-bottom:1px solid var(--hair-2);}
  .meta-row .label{font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--faint);text-transform:uppercase;width:120px;flex-shrink:0;padding-top:2px;}
  .meta-row .value{font-size:14px;line-height:1.5;color:var(--ink);}
  .v-sub{display:block;font-size:12px;color:var(--mute);margin-top:4px;}
  .sec-row{display:flex;gap:24px;padding:16px 0;border-bottom:1px solid var(--hair-2);}
  .sec-row .label{font-family:var(--mono);font-size:10px;letter-spacing:.14em;color:var(--faint);text-transform:uppercase;width:120px;flex-shrink:0;padding-top:2px;}
  .sec-strip{display:flex;gap:8px;margin-bottom:8px;}
  .sec-cell{padding:10px 14px;background:var(--bg-lift);flex:1;}
  .sec-mark{font-size:13px;font-weight:500;color:var(--ink);margin-bottom:3px;}
  .sec-sub{font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--faint);text-transform:uppercase;}
  .sec-strip-note{font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--faint);}
  @media(max-width:768px){.company-grid{grid-template-columns:1fr;gap:40px;}}

  /* HORIZON */
  section.horizon{background:var(--bg-2);margin:0 -40px;padding:80px 40px;border-top:1px solid var(--hair);}
  @media(max-width:768px){section.horizon{margin:0 -24px;padding:64px 24px;}}
  .h-inner{max-width:760px;}
  .h-mark{font-family:var(--mono);font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--faint);margin-bottom:24px;}
  .h-body{font-size:15px;line-height:1.7;color:var(--mute);}
  .h-body b{color:var(--ink);font-weight:500;}

  /* CLOSE */
  section.close{padding:96px 0;text-align:center;}
  section.close h2{font-size:clamp(32px,5vw,56px);max-width:none;text-align:center;}
  section.close p.lede{margin:0 auto 48px;text-align:center;}
  .cta-row{display:flex;justify-content:center;gap:16px;}

  /* FOOTER */
  footer.foot{
    border-top:1px solid var(--hair);
    padding:48px 0;
    display:grid; grid-template-columns:1fr 1fr 1fr;
    gap:40px; align-items:start;
  }
  .foot-brand b{display:block;font-size:15px;font-weight:500;color:var(--ink);margin-bottom:6px;}
  .foot-brand{font-size:13px;line-height:1.6;color:var(--mute);}
  .foot-links{display:flex;flex-direction:column;gap:10px;}
  .foot-links a{font-size:13px;color:var(--mute);text-decoration:none;transition:color .15s;}
  .foot-links a:hover{color:var(--ink);}
  .foot-final{text-align:right;}
  .foot-final div{font-size:12px;color:var(--mute);margin-bottom:4px;}
  .foot-sec{font-family:var(--mono);font-size:10px;letter-spacing:.08em;color:var(--faint);margin:6px 0;}
  @media(max-width:768px){footer.foot{grid-template-columns:1fr;}.foot-final{text-align:left;}}

  /* REVEAL ANIMATION */
  .reveal{opacity:0;transform:translateY(12px);transition:opacity .6s ease,transform .6s ease;}
  .reveal.in{opacity:1;transform:none;}

  /* LIVE FEED / RECORDS TALK */
  .records-talk{}
  .context-graph{}
</style>
</head>
<body>
  <slot />
<script is:inline>
  const reveals = document.querySelectorAll('section, .context-graph, .records-talk');
  reveals.forEach(el => el.classList.add('reveal'));
  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.06 });
  reveals.forEach(el => io.observe(el));

  const ucNav = document.getElementById('uc-nav');
  const ucButtons = ucNav ? ucNav.querySelectorAll('button') : [];
  const ucPanels = document.querySelectorAll('.uc-panel');
  ucButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.uc;
      ucButtons.forEach(b => b.classList.toggle('active', b === btn));
      ucPanels.forEach(p => p.classList.toggle('active', p.id === 'uc-' + id));
    });
  });
  if (ucButtons.length) ucButtons[0].click();
</script>
</body>
</html>
